# Copy this file to your ehaul config directory and populate with values
# from Google Cloud Console (APIs & Services > Credentials > OAuth 2.0
# Client IDs, "Desktop app" type).
#
# Config file location (os.UserConfigDir):
#   macOS:   ~/Library/Application Support/ehaul/credentials
#   Linux:   ~/.config/ehaul/credentials (or $XDG_CONFIG_HOME/ehaul/credentials)
#   Windows: %AppData%\ehaul\credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
